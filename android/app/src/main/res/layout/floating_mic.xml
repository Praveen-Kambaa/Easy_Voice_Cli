<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:background="@drawable/floating_mic_background"
    android:padding="8dp">

    <!-- Mic Button (IDLE state) -->
    <ImageView
        android:id="@+id/btn_mic"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_mic_normal"
        android:scaleType="centerInside"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Start Recording"
        android:visibility="visible" />

    <!-- Stop Button (RECORDING/PAUSED states) -->
    <ImageView
        android:id="@+id/btn_stop"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_stop"
        android:scaleType="centerInside"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Stop Recording"
        android:layout_marginEnd="8dp"
        android:visibility="gone" />

    <!-- Pause Button (RECORDING state) -->
    <ImageView
        android:id="@+id/btn_pause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_pause"
        android:scaleType="centerInside"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Pause Recording"
        android:visibility="gone" />

    <!-- Resume Button (PAUSED state) -->
    <ImageView
        android:id="@+id/btn_resume"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_resume"
        android:scaleType="centerInside"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Resume Recording"
        android:visibility="gone" />

</LinearLayout>
